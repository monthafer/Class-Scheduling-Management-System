  <SubComponents>
    <Component class="javax.swing.JTextPane" name="txt">
      <Properties>
        <Property name="editable" type="boolean" value="false"/>
        <Property name="foreground" type="java.awt.Color" editor="org.netbeans.beaninfo.editors.ColorEditor">
          <Color blue="85" green="85" red="85" type="rgb"/>
        </Property>
        <Property name="text" type="java.lang.String" value="          The &#x201c;Class Scheduling Management System&#x201d; is a digitalized class scheduling system that allows both teachers and students to efficiently manage their time and class schedule. The proponents of this project from the Grade 12 TVL ICT of MSU &#x2013; Marawi Senior High School developed the system on March 2022 to May 2023 to aid the occurring problems in regards with the school&#x2019;s scheduling management system. The system is facilitated by one or more school administrator that can easily access and manage the system. The users are both the teacher and the students of the institution."/>
      </Properties>
      <AuxValues>
        <AuxValue name="JavaCodeGenerator_VariableModifier" type="java.lang.Integer" value="1"/>
      </AuxValues>
    </Component>
    <Component class="javax.swing.JLabel" name="title">
      <Properties>
