          <Color blue="50" green="50" red="50" type="rgb"/>
        </Property>
        <Property name="text" type="java.lang.String" value="About this system, Class Scheduling Management System (CSMS):"/>
      </Properties>
      <AuxValues>
        <AuxValue name="JavaCodeGenerator_VariableModifier" type="java.lang.Integer" value="1"/>
