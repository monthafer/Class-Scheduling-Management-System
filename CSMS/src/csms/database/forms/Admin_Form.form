            <Property name="text" type="java.lang.String" value="&#x25ab; The SGS ID corresponds to the SGS ID in the SGS table. &#x25ab; The SGS ID can be nulled by leaving its text field blank. &#x25ab; Note that you cannot add or edit a student but you can remove them."/>
          </Properties>
          <AuxValues>
            <AuxValue name="JavaCodeGenerator_VariableModifier" type="java.lang.Integer" value="1"/>
          </AuxValues>
        </Component>
      </SubComponents>
    </Container>
  </SubComponents>
</Form>
